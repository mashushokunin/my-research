# =========================
# Python 仮想環境
# =========================
.venv/
venv/
env/

# =========================
# Python キャッシュ
# =========================
__pycache__/
*.py[cod]
*.pyo
*.pyd

# =========================
# Jupyter Notebook 関連
# =========================
.ipynb_checkpoints/

# =========================
# macOS / VS Code
# =========================
.DS_Store
.vscode/

# =========================
# 環境変数・秘密情報
# =========================
.env
.env.*
*.key
*.pem

# =========================
# データセット
# 大きい画像・動画・生データはGitHubに上げない
# =========================
data/raw/
data/processed/
data/interim/

# ただし、サンプルデータだけはGit管理してOK
!data/sample/
!data/sample/**

# =========================
# 実験結果
# 画像出力・ログ・モデル・キャリブレーション結果など
# =========================
results/
outputs/
logs/

# results/ の運用メモだけはGit管理する
!results/README.md

# =========================
# 画像・動画・重いファイル
# 必要なら data/sample/ に小さいサンプルだけ置く
# =========================
*.avi
*.mkv
*.bag
*.zip
*.tar
*.tar.gz
*.7z
*.mov
*.MOV
*.mp4
*.MP4

# =========================
# 学習済みモデル・重みファイル
# =========================
*.pt
*.pth
*.onnx
*.h5
*.ckpt

# =========================
# 一時ファイル
# =========================
*.tmp
*.log
